# ==========================================
# ShaderMind: Environment Configuration
# ==========================================
#
# Three independent auth surfaces — set the keys you actually use:
#
#   1. MiniMax M3 inference  → MINIMAX_API_KEY + MINIMAX_API_BASE
#      (powers every GLSL / planning / evolution / curation / narrative / consolidation call)
#
#   2. LiveKit voice room   → LIVEKIT_API_KEY + LIVEKIT_API_SECRET + LIVEKIT_URL
#      (powers the "Talk to ShaderMind" button; requires the agent/ subdir to be running)
#
#   3. MiniMax TTS          → MINIMAX_API_KEY (shared with #1) + MINIMAX_TTS_MODEL
#      (used by the LiveKit agent's voice output, NOT by the main server)
#
# DO and Gemini are opt-in: DigitalOcean via DO_INFERENCE_ROUTER (bypasses MiniMax entirely),
# Gemini via ALLOW_GEMINI_FALLBACK (kicks in only after MiniMax/DO exhausts).
# ==========================================


# ---- 1. MiniMax M3 inference (default for every AI call) ----
MINIMAX_API_BASE=https://api.minimax.io/v1
MINIMAX_API_KEY=
# Override the model name (default: minimax-m3)
# MINIMAX_INFERENCE_MODEL=minimax-m3
# Hard cap on every MiniMax call (default 5000ms)
MINIMAX_TIMEOUT_MS=5000


# ---- 2. DigitalOcean Inference (single model across all tasks) ----
# DO_INFERENCE_MODEL is the ONE knob that drives every AI task. Leave unset for the
# claude-opus-4.8 default, or set to any model your DO Inference account exposes.
# DO_MODELS_<TASK> env vars (advanced) override one task at a time.
DIGITAL_OCEAN_MODEL_ACCESS_KEY=
# DO_INFERENCE_MODEL=claude-opus-4.8
# Set DO_INFERENCE_ROUTER to route every task through a single DO Inference Router
# (sends router:<name> header instead of using the model name directly).
DO_INFERENCE_ROUTER=

# Per-task model pools (advanced). Each is a comma-separated fallback chain.
# If unset, falls back to DO_INFERENCE_MODEL for that task.
# DO_MODELS_PLANNING=
# DO_MODELS_GLSL=
# DO_MODELS_EVOLUTION=
# DO_MODELS_CURATION=
# DO_MODELS_NARRATIVE=
# DO_MODELS_CONSOLIDATION=


# ---- 3. Gemini fallback (opt-in) ----
# Only fires after MiniMax/DO pool exhausts. Set true to enable.
ALLOW_GEMINI_FALLBACK=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_GLSL_MODEL=gemini-3.5-flash
GEMINI_TIMEOUT_MS=90000


# ---- 4. LiveKit voice curator ----
# Powers the "Talk to ShaderMind" button. Requires the sibling agent/ project.
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=shadermind-curator
SHADERMIND_PUBLIC_URL=http://localhost:8080


# ---- 5. MiniMax TTS (used by the LiveKit agent, NOT by the main server) ----
# Same MINIMAX_API_KEY as #1 (MiniMax auth is unified per account).
MINIMAX_TTS_MODEL=speech-02-turbo
# MINIMAX_VOICE_ID=optional-voice-id


# ---- Inference timing + metrics ----
# Hard cap on every non-MiniMax call (Claude Opus via DO Inference, Gemini fallback, DO router).
# 30s default keeps full generation cycles in the 2–3 min budget. Tighten for demos.
AI_TIMEOUT_MS=30000

# Log every DO/Gemini/MiniMax call to stdout (in addition to in-memory tracking).
# Read aggregated totals anytime via GET /api/inference/metrics.
LOG_INFERENCE=false
INFERENCE_LOG_CAP=200


# ---- Generation pipeline ----
GENERATION_MODE=fast
BATCH_SIZE=3
GLSL_CONCURRENCY=3
GLSL_MAX_ATTEMPTS=1
GLSL_MAX_TOKENS=5000
REMIX_MUTATION=true
REMIX_SEED_LINES=40
PLANNING_RETRIES=1
PLANNING_MAX_TOKENS=4000
EVOLUTION_ASYNC=true


# ---- Learning engine ----
CODE_AWARE_LEARNING=true
LEARNING_CONTEXT_CHARS=9000
SHADER_SIMILARITY_THRESHOLD=0.92
LEARNING_MODE=human
HYBRID_TIMEOUT_MS=300000
CONSOLIDATION_EVERY_N=25
MAX_THUMBNAIL_BYTES=200000


# ---- Server ----
PORT=8080
AUTOPILOT=true
# When MONGODB_URI points at production Atlas, local dev skips autopilot by default
# so localhost and deployed stay in sync. Set true only for an isolated dev database.
AUTOPILOT_LOCAL=false
AUTOPILOT_INTERVAL_MS=0
AUTOPILOT_SEED_CYCLES=3


# ---- Storage ----
# When MONGODB_URI is set, Mongo is required — no fallback to database.json.
MONGODB_URI=
MONGODB_DB=shadermind
DB_PATH=./database.json

# Optional local SQLite (USE_SQLITE=true) with JSON mirror
USE_SQLITE=false
SQLITE_PATH=./shadermind.db
JSON_MIRROR=true


# ---- Agent (sibling project) ----
SHADERMIND_API_URL=http://localhost:8080
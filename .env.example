# ==========================================
# ShaderMind: Environment Configuration
# ==========================================

# Required — DigitalOcean Inference (primary)
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# Optional — DO Inference Router (routes to best model per task)
# Create in DO Control Panel → Inference → Inference Router
# Usage: set name only, code prefixes with router:
DO_INFERENCE_ROUTER=

# Per-task model pools (comma-separated, tried in order)
DO_MODELS_PLANNING=qwen3-coder-flash,llama3.3-70b-instruct,mistral-3-14B
DO_MODELS_GLSL=qwen3-coder-flash,glm-5.2,llama3.3-70b-instruct
DO_MODELS_EVOLUTION=deepseek-4-flash,llama-4-maverick,llama3.3-70b-instruct
DO_MODELS_CURATION=llama3.3-70b-instruct,mistral-3-14B,deepseek-4-flash
DO_MODELS_NARRATIVE=llama-4-maverick,deepseek-4-flash,llama3.3-70b-instruct
DO_MODELS_CONSOLIDATION=deepseek-4-flash,llama3.3-70b-instruct

AI_TIMEOUT_MS=120000

# Generation: fast = 1 LLM call with inline GLSL (default); staged = plan + N GLSL calls
GENERATION_MODE=fast
BATCH_SIZE=3
GLSL_CONCURRENCY=3
GLSL_MAX_ATTEMPTS=2
GLSL_MAX_TOKENS=5000
REMIX_MUTATION=true
PLANNING_RETRIES=1
PLANNING_MAX_TOKENS=4000

# After you rate 1–5, save ratings immediately and evolve strategy in background
EVOLUTION_ASYNC=true

# Code-aware learning engine
CODE_AWARE_LEARNING=true
LEARNING_CONTEXT_CHARS=9000
SHADER_SIMILARITY_THRESHOLD=0.82

# Optional — Gemini fallback if DO models fail
ALLOW_GEMINI_FALLBACK=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
GEMINI_GLSL_MODEL=gemini-3.5-flash

# Server
PORT=8080

# Storage — production MUST set MONGODB_URI (App Platform secret).
# When MONGODB_URI is set, Mongo is required — no fallback to database.json.
# Without MONGODB_URI, local dev uses database.json only.
MONGODB_URI=
MONGODB_DB=shadermind
DB_PATH=./database.json

# Optional local SQLite (USE_SQLITE=true) with JSON mirror for easy browsing
USE_SQLITE=false
SQLITE_PATH=./shadermind.db
JSON_MIRROR=true

# Learning loop: human | autonomous | hybrid
LEARNING_MODE=human
HYBRID_TIMEOUT_MS=300000
CONSOLIDATION_EVERY_N=25

# Autopilot — 0ms = start next batch as soon as you submit ratings
AUTOPILOT=true
# When MONGODB_URI points at production Atlas, local dev skips autopilot by default
# so localhost and deployed stay in sync. Set true only for an isolated dev database.
AUTOPILOT_LOCAL=false
AUTOPILOT_INTERVAL_MS=0
AUTOPILOT_SEED_CYCLES=3

# LiveKit voice curator (Studio "Talk to ShaderMind" button)
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_AGENT_NAME=shadermind-curator
# Public ShaderMind URL passed to the agent (production app URL)
SHADERMIND_PUBLIC_URL=http://localhost:8080

# MiniMax TTS for the LiveKit curator agent (plugin expects MINIMAX_API_KEY)
MINIMAX_API_KEY=
MINIMAX_TTS_MODEL=speech-02-turbo
# MINIMAX_VOICE_ID=optional-voice-id

# Agent reads GEMINI via GOOGLE_API_KEY alias (set GEMINI_API_KEY above)
# Local agent API target when testing against npm run dev:
SHADERMIND_API_URL=http://localhost:8080
# ==========================================
# ShaderMind: Environment Configuration
# ==========================================

# 1. Google Gemini API Key (Required for batch generation)
GEMINI_API_KEY=

# Gemini models — batch pipeline uses Gemini exclusively by default
GEMINI_MODEL=gemini-2.5-flash
GEMINI_GLSL_MODEL=gemini-2.5-pro
GEMINI_ONLY=true

# Code-aware learning
CODE_AWARE_LEARNING=true
LEARNING_CONTEXT_CHARS=9000
SHADER_SIMILARITY_THRESHOLD=0.82

# 2. DigitalOcean fallback (disabled unless explicitly enabled)
ALLOW_DO_FALLBACK=false
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# 3. Server Port Configuration (Defaults to 8080)
PORT=8080

# 4. Autonomous Mode (runs without user input)
AUTOPILOT=true
AUTOPILOT_INTERVAL_MS=45000
AUTOPILOT_SEED_CYCLES=3

# ==========================================
# ShaderMind: Environment Configuration
# ==========================================

# Required — DigitalOcean Inference (primary)
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# Optional — DO Inference Router (routes to best model per task)
# Create in DO Control Panel → Inference → Inference Router
# Usage: set name only, code prefixes with router:
DO_INFERENCE_ROUTER=

# Per-task model pools (comma-separated, tried in order)
DO_MODELS_PLANNING=qwen3-coder-flash,llama3.3-70b-instruct,mistral-3-14B
DO_MODELS_GLSL=qwen3-coder-flash,glm-5.2,llama3.3-70b-instruct
DO_MODELS_EVOLUTION=deepseek-4-flash,llama-4-maverick,llama3.3-70b-instruct
DO_MODELS_CURATION=llama3.3-70b-instruct,mistral-3-14B,deepseek-4-flash
DO_MODELS_NARRATIVE=llama-4-maverick,deepseek-4-flash,llama3.3-70b-instruct
DO_MODELS_CONSOLIDATION=deepseek-4-flash,llama3.3-70b-instruct

AI_TIMEOUT_MS=120000
GLSL_CONCURRENCY=3

# Optional — Gemini fallback if DO models fail
ALLOW_GEMINI_FALLBACK=false
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server
PORT=8080

# Storage — omit MONGODB_URI to use database.json locally
MONGODB_URI=
MONGODB_DB=shadermind
DB_PATH=./database.json

# Learning loop: human | autonomous | hybrid
LEARNING_MODE=human
HYBRID_TIMEOUT_MS=300000
CONSOLIDATION_EVERY_N=25

# Autopilot
AUTOPILOT=true
AUTOPILOT_INTERVAL_MS=45000
AUTOPILOT_SEED_CYCLES=3
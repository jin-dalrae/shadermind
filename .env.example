# ==========================================
# ShaderMind: Environment Configuration
# ==========================================

# 1. Google Gemini Developer API Key (Highly Recommended)
# This is used to drive rapid, structured JSON schema outputs for 5-3-2 generations
GEMINI_API_KEY=

# 2. DigitalOcean AI Fallback Key (Llama-3.3-70b Inference)
# Used automatically as a resilient fallback if Gemini is not present
DIGITAL_OCEAN_MODEL_ACCESS_KEY=

# 3. Server Port Configuration (Defaults to 8080)
PORT=8080

# 4. Autonomous Mode (runs without user input)
AUTOPILOT=true
AUTOPILOT_INTERVAL_MS=45000
AUTOPILOT_SEED_CYCLES=3
